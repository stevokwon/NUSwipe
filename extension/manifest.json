{
  "manifest_version": 3,
  "name": "NUSwipe Auto-Apply",
  "version": "0.1.0",
  "description": "Automatically submits job applications from NUSwipe",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "http://localhost:3000/*",
    "https://*.nuswipe.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NUSwipe Auto-Apply"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://*.nuswipe.com/*"],
      "js": ["content-nusw.js"]
    },
    {
      "matches": ["https://boards.greenhouse.io/*"],
      "js": ["content-greenhouse.js"]
    },
    {
      "matches": ["https://jobs.lever.co/*"],
      "js": ["content-lever.js"]
    }
  ]
}
